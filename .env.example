# ── Supabase ────────────────────────────────────────────────
# Painel do projeto Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-anon-key-publica"
# Usada APENAS no servidor (nunca exponha no frontend)
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"

# ── Banco (Prisma) ──────────────────────────────────────────
# Settings → Database → Connection string (use a "Connection pooling" para serverless)
DATABASE_URL="postgresql://postgres:SENHA@db.SEU-PROJETO.supabase.co:5432/postgres?schema=public"
DIRECT_URL="postgresql://postgres:SENHA@db.SEU-PROJETO.supabase.co:5432/postgres?schema=public"

# ── Pagamento (definido na Fase 3) ──────────────────────────
# Gateway brasileiro para a compra única de R$ 449,90 (acesso vitalício)
