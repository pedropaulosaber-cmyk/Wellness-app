// Schema do Vivá — evolui por fase. Cada nova tabela com dado de usuário
// deve nascer com RLS no Supabase (ver skill supabase-rls-guard).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Enums (espelham src/lib/nutrition.ts) ────────────────────

enum Sexo {
  masculino
  feminino
}

enum NivelAtividade {
  sedentario
  leve
  moderado
  intenso
  muito_intenso
}

enum Objetivo {
  emagrecer
  manter
  ganhar_massa
}

// ── Usuário e modelo de negócio (acesso VITALÍCIO) ───────────

/// Espelha o usuário do Supabase Auth (id = auth.users.id).
model Usuario {
  id    String  @id @db.Uuid // = auth.uid()
  email String  @unique
  nome  String?

  // Modelo de negócio: pagamento ÚNICO de R$ 449,90 = acesso vitalício.
  // NÃO é assinatura.
  acessoVitalicio Boolean   @default(false)
  compraEm        DateTime?

  // Token para sincronização de wearables (Apple Health via Atalhos,
  // Health Connect, ou wrapper nativo) chamarem o endpoint de import.
  syncToken String? @unique

  perfil     Perfil?
  registros  RegistroAlimentar[]
  aguas      RegistroAgua[]
  sessoes    TreinoSessao[]
  pesos      RegistroPeso[]
  atividades RegistroAtividadeExterna[]
  criadoEm   DateTime                   @default(now())

  @@map("usuarios")
}

// ── Anamnese / Perfil ────────────────────────────────────────

model Perfil {
  id        String  @id @default(uuid()) @db.Uuid
  usuarioId String  @unique @db.Uuid
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  // Dados corporais
  sexo           Sexo
  idade          Int
  pesoKg         Float
  alturaCm       Float
  nivelAtividade NivelAtividade
  objetivo       Objetivo

  // Anamnese aprofundada (fundador é fisioterapeuta — lesões importam)
  rotinaTrabalho    String? // ex.: "escritório 8h", "operacional em pé"
  horasSono         Float? // média por noite
  qualidadeSono     Int? // 1–5
  lesoes            String? // texto livre / limitações
  experienciaTreino String? // iniciante | intermediario | avancado

  // Modalidades escolhidas (ex.: ["musculacao","corrida"])
  modalidades String[]
  restricoes  String[] // alimentares

  // Snapshot do plano calculado (recalculado quando muda peso/objetivo/rotina)
  caloriasAlvo Int?
  proteinaG    Int?
  carboidratoG Int?
  gorduraG     Int?
  aguaMl       Int?

  atualizadoEm DateTime @default(now()) @updatedAt

  @@map("perfis")
}

// ── Registro alimentar e hidratação ──────────────────────────
// IMPORTANTE: como o acesso aos dados é via Prisma (conexão privilegiada que
// ignora RLS), o ISOLAMENTO entre contas é garantido na APLICAÇÃO — toda query
// filtra por usuarioId. Ver prisma/rls.sql para defesa em profundidade.

model RegistroAlimentar {
  id        String  @id @default(uuid()) @db.Uuid
  usuarioId String  @db.Uuid
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  dia      String // YYYY-MM-DD (fuso America/Sao_Paulo)
  refeicao String // cafe | almoco | lanche | pre_treino | jantar | avulso
  nome     String
  gramas   Int
  kcal     Int
  proteina Int
  carbo    Int
  gordura  Int
  criadoEm DateTime @default(now())

  @@index([usuarioId, dia])
  @@map("registros_alimentares")
}

model RegistroAgua {
  id        String  @id @default(uuid()) @db.Uuid
  usuarioId String  @db.Uuid
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  dia      String
  ml       Int
  criadoEm DateTime @default(now())

  @@index([usuarioId, dia])
  @@map("registros_agua")
}

// ── Treinos ──────────────────────────────────────────────────

model TreinoSessao {
  id        String  @id @default(uuid()) @db.Uuid
  usuarioId String  @db.Uuid
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  dia         String // YYYY-MM-DD
  modalidade  String
  nome        String
  tipo        String // forca | cardio | mobilidade
  duracaoMin  Int?
  distanciaKm Float?
  paceSeg     Int? // segundos por km (cardio)
  series      SerieRegistro[]
  criadoEm    DateTime        @default(now())

  @@index([usuarioId, dia])
  @@map("treino_sessoes")
}

model SerieRegistro {
  id        String       @id @default(uuid()) @db.Uuid
  sessaoId  String       @db.Uuid
  sessao    TreinoSessao @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  usuarioId String       @db.Uuid // desnormalizado p/ consultar progressão por usuário

  exercicioId   String
  exercicioNome String
  serie         Int
  reps          Int
  cargaKg       Float?
  criadoEm      DateTime @default(now())

  @@index([usuarioId, exercicioId])
  @@map("serie_registros")
}

// ── Evolução (peso / medidas) ────────────────────────────────

model RegistroPeso {
  id        String  @id @default(uuid()) @db.Uuid
  usuarioId String  @db.Uuid
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  dia       String
  pesoKg    Float
  cinturaCm Float?
  criadoEm  DateTime @default(now())

  @@index([usuarioId, dia])
  @@map("registros_peso")
}

// ── Integrações (wearables / apps de saúde) ──────────────────

model RegistroAtividadeExterna {
  id        String  @id @default(uuid()) @db.Uuid
  usuarioId String  @db.Uuid
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  dia               String
  fonte             String // apple_health | google_fit | health_connect | manual
  passos            Int?
  caloriasAtivas    Int?
  freqCardiacaMedia Int?
  atualizadoEm      DateTime @default(now()) @updatedAt

  @@unique([usuarioId, dia, fonte])
  @@index([usuarioId, dia])
  @@map("atividades_externas")
}
